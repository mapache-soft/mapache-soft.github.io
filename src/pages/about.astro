---
import Layout from '../layouts/Layout.astro';
import { url } from '../lib/url';
---

<Layout
	title="About — Mapache Softworks"
	description="Learn about Mapache Softworks: the founder, operating principles, and how we build independent apps and software consulting services."
>
	<section class="hero">
		<div class="container">
			<p class="eyebrow">About the company</p>
			<h1>Small studio, careful software.</h1>
			<p class="lede">
				Mapache Softworks is an independent software company run from Vienna. We ship our own apps and help teams build software that is useful, understandable, and respectful of the people who use it.
			</p>
		</div>
	</section>

	<section>
		<div class="container split">
			<div>
				<p class="eyebrow">Principles</p>
				<h2>How we work.</h2>
			</div>
			<div class="panel">
				<ul class="list">
					<li><strong>Own the product:</strong> We build things we are proud to maintain and support for years.</li>
					<li><strong>Respect the user:</strong> Privacy defaults, local processing, and clear choices matter.</li>
					<li><strong>Keep it understandable:</strong> Simple systems and clear code age better than clever ones.</li>
					<li><strong>Ship steadily:</strong> Small improvements, released often, beat giant unreleased plans.</li>
				</ul>
			</div>
		</div>
	</section>

	<section>
		<div class="container split">
			<div>
				<p class="eyebrow">Founder</p>
				<h2>Carmen Huidobro</h2>
			</div>
			<div class="panel founder">
				<img class="founder-photo" src={url('/carmen.jpg')} alt="Carmen Huidobro" />
				<p>
					Carmen is the founder of Mapache Softworks. She builds independent apps and helps teams create software that is useful, understandable, and respectful of the people who use it.
				</p>
				<p>
					Mapache Softworks is intentionally small, which keeps communication direct and decisions fast. For larger projects we collaborate with a trusted network of designers, engineers, and specialists.
				</p>
				<div class="card-actions">
					<a class="button" href="mailto:hello@mapache-soft.com">Say hello</a>
					<a class="button-secondary" href={url('/services/')}>See services</a>
				</div>
			</div>
		</div>
	</section>

	<section>
		<div class="container grid">
			<article class="card">
				<h3>Location</h3>
				<p>Based in Vienna, Austria. Remote-friendly and happy to work with teams across Europe and beyond.</p>
			</article>
			<article class="card">
				<h3>Company</h3>
				<p>Mapache Softworks is registered in Austria. For legal details, see the <a href={url('/impressum/')}>Impressum</a>.</p>
			</article>
			<article class="card">
				<h3>Contact</h3>
				<p>Questions, project ideas, or support requests are welcome at <a href="mailto:hello@mapache-soft.com">hello@mapache-soft.com</a>.</p>
			</article>
		</div>
	</section>
</Layout>

<style>
	.founder-photo {
		width: 100%;
		max-width: 320px;
		border-radius: 24px;
		margin-bottom: 24px;
	}
</style>
