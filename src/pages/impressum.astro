---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Impressum — Mapache Softworks GmbH"
	description="Legal notice for Mapache Softworks GmbH."
>
	<section class="hero">
		<div class="container legal">
			<p class="eyebrow">Legal notice</p>
			<h1>Impressum</h1>
			<p class="lede">This page is a launch draft. Replace the placeholders with verified company details before publishing mapache-soft.com.</p>
		</div>
	</section>

	<section>
		<div class="container legal panel">
			<h2>Angaben gemäß § 5 ECG und § 14 UGB</h2>
			<dl>
				<dt>Company</dt>
				<dd>Mapache Softworks GmbH</dd>
				<dt>Registered address</dt>
				<dd>[Street address], [Postal code] [City], Austria</dd>
				<dt>Managing director</dt>
				<dd>[Name]</dd>
				<dt>Commercial register</dt>
				<dd>[Court and company register number]</dd>
				<dt>VAT ID</dt>
				<dd>[VAT identification number, if applicable]</dd>
				<dt>Email</dt>
				<dd><a href="mailto:hello@mapache-soft.com">hello@mapache-soft.com</a></dd>
				<dt>Website</dt>
				<dd><a href="https://mapache-soft.com">mapache-soft.com</a></dd>
			</dl>

			<h2>Responsible for content</h2>
			<p>Mapache Softworks GmbH, represented by the managing director listed above.</p>

			<h2>Dispute resolution</h2>
			<p>The European Commission provides an online dispute resolution platform at <a href="https://ec.europa.eu/consumers/odr/">ec.europa.eu/consumers/odr</a>.</p>

			<h2>Liability for external links</h2>
			<p>External links are provided for convenience. Mapache Softworks GmbH is not responsible for the content of external websites.</p>
		</div>
	</section>
</Layout>
