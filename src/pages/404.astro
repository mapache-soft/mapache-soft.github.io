---
import Layout from '../layouts/Layout.astro';
import { url } from '../lib/url';
---

<Layout
	title="Page not found — Mapache Softworks"
	description="Sorry, requested page could not be found."
>
	<section class="hero">
		<div class="container">
			<p class="eyebrow">404</p>
			<h1>Page not found</h1>
			<p class="lede">The page you are looking for does not exist or has moved.</p>
			<div class="hero-actions">
				<a class="button" href={url('/')}>Back to home</a>
				<a class="button-secondary" href="mailto:hola@mapache-soft.com">Get in touch</a>
			</div>
		</div>
	</section>
</Layout>
