---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Mapache Softworks',
	description = 'Independent software company for thoughtful Mac apps and product-minded engineering consulting.',
} = Astro.props;

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/apps/', label: 'Apps' },
	{ href: '/services/', label: 'Services' },
	{ href: '/about/', label: 'About' },
	{ href: '/impressum/', label: 'Impressum' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<header class="site-header">
			<div class="container header-grid">
				<a class="brand" href="/" aria-label="Mapache Softworks home">
					<span class="brand-mark">MS</span>
					<span>
						<strong>Mapache Softworks</strong>
						<small>Apps, systems, and careful software work</small>
					</span>
				</a>
				<nav aria-label="Primary navigation">
					<ul>
						{navItems.map((item) => (
							<li>
								<a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>
							</li>
						))}
					</ul>
				</nav>
			</div>
		</header>
		<main id="main-content" tabindex="-1">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="container footer-grid">
				<p>© 2026 Mapache Softworks. All rights reserved.</p>
				<nav aria-label="Footer navigation">
					<a href="/impressum/">Impressum</a>
					<a href="/privacy/">Privacy</a>
					<a href="mailto:hello@mapache-soft.com">hello@mapache-soft.com</a>
				</nav>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--color-ink: #231c2d;
		--color-muted: #6f6482;
		--color-subtle: #9a91a8;
		--color-paper: #f9f6fc;
		--color-card: #ffffff;
		--color-line: #e2d8ec;
		--color-primary: #7553a6;
		--color-primary-dark: #563c7a;
		--color-accent: #a883f4;
		--color-accent-soft: #ede5f9;
		--shadow-soft: 0 24px 80px rgba(63, 40, 98, 0.12);
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: var(--color-ink);
		background: var(--color-paper);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		background:
			radial-gradient(circle at top left, rgba(168, 131, 244, 0.24), transparent 36rem),
			linear-gradient(135deg, #f9f6fc 0%, #f1ebf8 42%, #fff 100%);
		color: var(--color-ink);
		font-size: 18px;
		line-height: 1.6;
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		background-image: linear-gradient(rgba(117, 83, 166, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(117, 83, 166, 0.05) 1px, transparent 1px);
		background-size: 48px 48px;
		content: "";
		mask-image: linear-gradient(to bottom, black, transparent 80%);
	}

	a {
		color: var(--color-primary);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	a:hover {
		color: var(--color-primary-dark);
	}

	img {
		max-width: 100%;
	}

	.container {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
	}

	.skip-link {
		position: absolute;
		top: 12px;
		left: 12px;
		z-index: 10;
		transform: translateY(-200%);
		border-radius: 999px;
		background: var(--color-ink);
		color: white;
		padding: 10px 16px;
	}

	.skip-link:focus {
		transform: translateY(0);
	}

	.site-header {
		padding: 28px 0;
	}

	.header-grid,
	.footer-grid {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		color: var(--color-ink);
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		width: 48px;
		height: 48px;
		place-items: center;
		border-radius: 16px;
		background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		color: white;
		font-size: 0.86rem;
		font-weight: 800;
		letter-spacing: 0.08em;
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand small {
		color: var(--color-muted);
		font-size: 0.82rem;
	}

	nav ul {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	nav a {
		display: inline-flex;
		align-items: center;
		border-radius: 999px;
		padding: 8px 13px;
		color: var(--color-ink);
		font-size: 0.95rem;
		font-weight: 650;
		text-decoration: none;
	}

	nav a:hover,
	nav a[aria-current="page"] {
		background: var(--color-accent-soft);
		color: var(--color-primary-dark);
	}

	section {
		padding: 56px 0;
	}

	.eyebrow {
		margin: 0 0 14px;
		color: var(--color-primary);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		line-height: 1.05;
		letter-spacing: -0.04em;
	}

	h1 {
		max-width: 900px;
		font-size: clamp(2.5rem, 5vw, 4rem);
	}

	h2 {
		font-size: clamp(2.1rem, 5vw, 4rem);
	}

	h3 {
		font-size: clamp(1.35rem, 2vw, 1.8rem);
	}

	.lede {
		max-width: 760px;
		margin: 24px 0 0;
		color: var(--color-muted);
		font-size: clamp(1.2rem, 2vw, 1.5rem);
		line-height: 1.45;
	}

	.hero {
		padding: 88px 0 64px;
	}

	.hero-actions,
	.card-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 32px;
	}

	.button,
	.button-secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		padding: 12px 18px;
		font-weight: 750;
		text-decoration: none;
	}

	.button {
		background: var(--color-primary);
		color: white;
		box-shadow: 0 14px 30px rgba(125, 64, 86, 0.24);
	}

	.button:hover {
		background: var(--color-primary-dark);
		color: white;
	}

	.button-secondary {
		border: 1px solid var(--color-line);
		background: rgba(255, 255, 255, 0.72);
		color: var(--color-primary-dark);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.grid.two {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.card,
	.panel {
		border: 1px solid var(--color-line);
		border-radius: 28px;
		background: rgba(255, 255, 255, 0.78);
		box-shadow: var(--shadow-soft);
	}

	.card {
		padding: 28px;
	}

	.panel {
		padding: clamp(28px, 4vw, 48px);
	}

	.card p,
	.panel p,
	.legal p,
	.legal li {
		color: var(--color-muted);
	}

	.card h3 + p,
	.panel h2 + p {
		margin-top: 16px;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 20px 0 0;
		padding: 0;
		list-style: none;
	}

	.tag-list li {
		border: 1px solid var(--color-line);
		border-radius: 999px;
		background: #fffaf6;
		padding: 5px 10px;
		color: var(--color-primary-dark);
		font-size: 0.85rem;
		font-weight: 700;
	}

	.split {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
		gap: clamp(28px, 6vw, 72px);
		align-items: start;
	}

	.list {
		display: grid;
		gap: 16px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.list li {
		border-left: 3px solid var(--color-accent);
		padding-left: 16px;
	}

	.site-footer {
		padding: 36px 0 48px;
		color: var(--color-muted);
		font-size: 0.92rem;
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer nav {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.legal {
		max-width: 820px;
	}

	.legal dl {
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: 12px 24px;
		margin: 32px 0;
	}

	.legal dt {
		font-weight: 800;
	}

	.legal dd {
		margin: 0;
		color: var(--color-muted);
	}

	@media (max-width: 820px) {
		.header-grid,
		.footer-grid,
		.split {
			display: grid;
			grid-template-columns: 1fr;
		}

		.grid,
		.grid.two {
			grid-template-columns: 1fr;
		}

		section {
			padding: 40px 0;
		}

		.hero {
			padding-top: 48px;
		}
	}

	@media (max-width: 560px) {
		body {
			font-size: 16px;
		}

		nav a {
			padding: 7px 10px;
		}

		.legal dl {
			grid-template-columns: 1fr;
			gap: 4px;
		}
	}
</style>
